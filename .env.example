# Postgres (used by docker-compose)
POSTGRES_DB=monthly_giving
POSTGRES_TEST_DB=monthly_giving_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database
# Matches docker-compose defaults — update if using an external DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monthly_giving
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5433/monthly_giving_test

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe
STRIPE_PRICE_ID=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
